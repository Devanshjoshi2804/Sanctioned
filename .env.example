# Environment for the Python services. Copy to `.env` (gitignored) and fill in.
# Everything here is OPTIONAL — the system runs fully without any of it (the
# copilot falls back to offline retrieval; AA ingestion falls back to the mock).

# --- Copilot (Gemini) ---------------------------------------------------------
# When set, the copilot embeds + synthesises with Gemini; otherwise offline TF-IDF.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Setu Account Aggregator (real bank-statement ingestion) ------------------
# Sandbox credentials from the Setu Bridge console. When set, SetuAaSource performs
# the real consent -> data-session -> fetch flow. Without them, ingestion uses the
# labelled mock statement.
SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
